<launch>
  <arg name="open_nav_rviz" default="true"/>
  <arg name="map_file_name" default="reicom"/>
  <arg name="map_directory" default="$(env MAP_DIRECTORY)"/>
	<arg name="location_method" default="amcl_sim" 
				doc="location type [amcl_sim, cartographer_sim]"/>
	<!--bobac3 model description-->
  <include file="$(find bobac3_description)/launch/gazebo.launch">
    <arg name="open_rviz" value="false"/>
  </include>
	<!--map_server-->
	<include file="$(find map_manager)/launch/map_load.launch">
		<arg name="map_file" value="$(arg map_file_name)"/>
		<arg name="map_directory" value="$(arg map_directory)"/>
	</include>
	<!--move_base-->
	<include file="$(find bobac3_navigation)/launch/move_base_sim.launch"/>
	<!--location-->
	<include file="$(find bobac3_navigation)/launch/$(arg location_method).launch">
	 <arg name="map_file" value="$(arg map_file_name)"/>
	</include>
	<node name="virtual_wall_map_publisher" pkg="ros_map_edit" type="virtual_wall_map_publisher.py">
		<param name="map_file" value="$(arg map_directory)/$(arg map_file_name).yaml"/>
	</node>
	
	<!--  **************** Visualisation ****************  -->
  <group if="$(arg open_nav_rviz)"> 
    <node pkg="rviz" type="rviz" name="rviz"
          args="-d $(find bobac3_navigation)/rviz/robot_navigation.rviz"/>
  </group>
</launch>
